{
  "entities": {
    "observation": {
      "title": "Observation de biodiversité",
      "description": "Une observation d'un organisme faite par un plongeur",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID de l'utilisateur" },
        "nomCommun": { "type": "string", "description": "Nom commun de l'organisme" },
        "nomScientifique": { "type": "string", "description": "Nom scientifique" },
        "latitude": { "type": "number", "description": "Latitude de l'observation" },
        "longitude": { "type": "number", "description": "Longitude de l'observation" },
        "date": { "type": "string", "format": "date-time", "description": "Date de l'observation" },
        "imageUrl": { "type": "string", "description": "URL de la photo" }
      },
      "required": ["userId", "nomCommun", "latitude", "longitude", "date"]
    }
  },
  "firestore": {
    "/observations/{observationId}": {
      "schema": "observation",
      "description": "Collection des observations de biodiversité"
    }
  }
}
