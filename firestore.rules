rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Safety Net: Deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'pjl.galland@gmail.com' ||
        request.auth.token.email == 'Py.buri@hotmail.com'
      );
    }

    // 2. User Stats Protection
    match /users/{userId}/stats/usage {
      allow read: if isOwner(userId) || isAdmin();
      
      // Creating the doc for the first time
      allow create: if isOwner(userId) 
        && request.resource.data.userId == userId
        && request.resource.data.dailyCount <= 1;

      // Updating stats
      allow update: if (isOwner(userId) || isAdmin()) 
        && (
          // Case 1: Simple increment OR reset to 1 for new day
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dailyCount', 'lastAnalysisDate'])
           && (request.resource.data.dailyCount == resource.data.dailyCount + 1 || request.resource.data.dailyCount == 1))
          ||
          // Case 2: Update premium status or center branding
          (request.resource.data.diff(resource.data).affectedKeys().hasAny(['isPremium', 'isDiveCenter', 'centerName', 'centerLogoUrl']))
          ||
          // Case 3: Admin override
          isAdmin()
        );
    }
  }
}
